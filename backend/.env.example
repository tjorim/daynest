# Legacy single-file example.
# Prefer backend/env/{dev,staging,prod}.env with docker-compose.
ENVIRONMENT=dev
DB_HOST=postgres
DB_PORT=5432
DB_NAME=daynest
DB_USER=daynest
DB_PASSWORD_FILE=/run/secrets/postgres_password
OIDC_ISSUER_URL=http://keycloak:8080/realms/daynest
# Required in non-dev environments; matches the access token audience claim.
OIDC_AUDIENCE=daynest
OIDC_ALGORITHMS=RS256
# Optional; discovered from {issuer}/.well-known/openid-configuration when empty.
OIDC_JWKS_URI=
UPCOMING_HORIZON_DAYS=7
MEDICATION_MISSED_GRACE_MINUTES=30
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRUSTED_HOSTS=localhost,127.0.0.1
DAYNEST_USER_EMAIL=
DAYNEST_MCP_RESOURCE_SERVER_URL=http://127.0.0.1:8000/mcp
# Optional / security
METRICS_SECRET=
INTEGRATION_KEY_HASH_SECRET=
PASSWORD_HASH_ITERATIONS=390000
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_FILE=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=
# Per-client-IP rate limit applied to every /api route (health probes are
# exempt). Set RATE_LIMIT_ENABLED=false to disable entirely.
# RATE_LIMIT_DEFAULT uses the flask-limiter/slowapi rate string format, e.g.
# "200/minute", "10/second", "5000/hour".
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=200/minute
