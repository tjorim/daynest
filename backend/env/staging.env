ENVIRONMENT=staging
DB_HOST=postgres
DB_PORT=5432
DB_NAME=daynest
DB_USER=daynest
DB_PASSWORD_FILE=/run/secrets/postgres_password
OIDC_ISSUER_URL=https://auth.daynest.example/realms/daynest
OIDC_ALGORITHMS=RS256
CORS_ALLOW_ORIGINS=https://staging.daynest.example
TRUSTED_HOSTS=staging.daynest.example
