ENVIRONMENT=staging
DB_HOST=postgres
DB_PORT=5432
DB_NAME=daynest
DB_USER=daynest
DB_PASSWORD_FILE=/run/secrets/postgres_password
JWT_SECRET_FILE=/run/secrets/jwt_secret
ACCESS_TOKEN_EXPIRE_MINUTES=20
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ALLOW_ORIGINS=https://staging.daynest.example
TRUSTED_HOSTS=staging.daynest.example
