ENVIRONMENT=prod
DB_HOST=postgres
DB_PORT=5432
DB_NAME=daynest
DB_USER=daynest
DB_PASSWORD_FILE=/run/secrets/postgres_password
OIDC_ISSUER_URL=https://auth.daynest.example/realms/daynest
OIDC_AUDIENCE=daynest
OIDC_ALGORITHMS=RS256
INTEGRATION_KEY_HASH_SECRET_FILE=/run/secrets/integration_key_hash_secret
CORS_ORIGINS=https://daynest.example
TRUSTED_HOSTS=daynest.example
